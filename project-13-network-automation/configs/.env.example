# Project 13 credential environment example.
# Copy values into your shell session or a local .env file that is never committed.

NETLAB_USERNAME=
NETLAB_PASSWORD=
NETLAB_SECRET=

# Optional device-specific override example.
NETLAB_WAN_RTR1_USERNAME=
NETLAB_WAN_RTR1_PASSWORD=
NETLAB_WAN_RTR1_SECRET=

# Optional ASA override example.
NETLAB_ASA_USERNAME=
NETLAB_ASA_PASSWORD=
NETLAB_ASA_SECRET=
